<Window x:Class="applanch.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:applanch.Controls"
        xmlns:res="clr-namespace:applanch.Properties"
        SizeToContent="Height"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Background="{DynamicResource Brush.AppBackground}">
    <Window.Resources>

        <!-- Item inside the dropdown list -->
        <Style x:Key="DialogComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.ItemBackground}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.ItemBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogComboBoxToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Implicit style overrides the WPF theme style that has FindAncestor bindings. -->
        <Style TargetType="ComboBoxItem"
               BasedOn="{StaticResource DialogComboBoxItemStyle}"/>

        <!-- ComboBox styled to match the TextBox -->
        <Style x:Key="DialogComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.ItemBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DialogComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Visible border, identical to DialogTextBoxStyle -->
                            <Border x:Name="OuterBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <!-- Editable text area -->
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Margin="10,0,30,0"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             MinHeight="0"
                                             FontSize="{TemplateBinding FontSize}"
                                             Foreground="{TemplateBinding Foreground}"
                                             CaretBrush="{DynamicResource Brush.TextPrimary}" />
                                    <!-- Real toggle button so the control behaves as a true ComboBox -->
                                    <ToggleButton x:Name="DropDownToggle"
                                                  Width="28"
                                                  HorizontalAlignment="Right"
                                                  Margin="0"
                                                  Style="{StaticResource DialogComboBoxToggleButtonStyle}"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <Path Width="12"
                                              Height="8"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 1 1 L 6 7 L 11 1"
                                              Stroke="{DynamicResource Brush.TextTertiary}"
                                              StrokeThickness="1.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- Dropdown popup — WPF manages placement automatically -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade"
                                   VerticalOffset="4">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="200"
                                        Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.ItemBorder}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer Margin="4"
                                                  Focusable="False"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource Brush.SurfaceBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource Brush.SurfaceBorder}" />
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource Brush.ItemBackground}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource Brush.SurfaceBorder}" />
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource Brush.ItemBackground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Plain text input -->
        <Style x:Key="DialogTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource RoundedTextBoxStyle}">
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <!-- Text-only mode -->
        <TextBox x:Name="InputTextBox"
                 Style="{StaticResource DialogTextBoxStyle}" />
        <!-- Suggestion mode: SuggestionInputControl wraps ComboBox logic -->
        <controls:SuggestionInputControl x:Name="InputSuggestion"
                                         InputComboBoxStyle="{StaticResource DialogComboBoxStyle}"
                                         Visibility="Collapsed" />
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button x:Name="CancelButton"
                        Content="{x:Static res:Resources.Button_Cancel}"
                    Width="100"
                    IsCancel="True" />
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="80"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    Click="OkButton_Click" />
        </StackPanel>
    </StackPanel>
</Window>