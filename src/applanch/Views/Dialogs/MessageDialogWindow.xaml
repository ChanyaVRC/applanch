<Window x:Class="applanch.MessageDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="Height"
    Width="452"
    MinWidth="360"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Background="{DynamicResource Brush.AppBackground}">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="IconSpacerColumn" Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="IconBadge"
                    Width="36"
                    Height="36"
                    CornerRadius="18"
                    Margin="0,1,0,0"
                    VerticalAlignment="Top"
                    Background="Transparent">
                <TextBlock x:Name="IconText"
                           FontFamily="Segoe Fluent Icons"
                           FontSize="22"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextSecondary}"/>
            </Border>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="240">
                <TextBlock x:Name="MessageText"
                           TextWrapping="Wrap"
                           FontSize="14"
                           LineHeight="22"
                           Foreground="{DynamicResource Brush.TextPrimary}"/>
            </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Content="OK"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
