<UserControl x:Class="applanch.Controls.SuggestionInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <ComboBox x:Name="InputComboBox"
              Style="{Binding InputComboBoxStyle, ElementName=Root}"
              IsEditable="True"
              IsTextSearchEnabled="False"
              StaysOpenOnEdit="True"
              ItemsSource="{Binding FilteredSuggestions, ElementName=Root}"
              Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              SelectionChanged="ComboBox_SelectionChanged"
              PreviewMouseLeftButtonUp="ComboBox_PreviewMouseLeftButtonUp"
              ToolTip="{Binding ToolTip, ElementName=Root}" />
</UserControl>
