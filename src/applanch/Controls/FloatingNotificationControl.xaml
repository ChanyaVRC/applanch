<UserControl x:Class="applanch.Controls.FloatingNotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:applanch.ViewModels"
             x:Name="Root"
             Visibility="Collapsed"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="Auto">
    <UserControl.Resources>
        <Storyboard x:Key="FloatingNotificationSlideInStoryboard">
            <DoubleAnimation Storyboard.TargetName="FloatingNotificationTranslate"
                             Storyboard.TargetProperty="Y"
                             From="18"
                             To="0"
                             Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FloatingNotificationCountdownStoryboard">
            <DoubleAnimation Storyboard.TargetName="FloatingNotificationProgressScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="0"
                             Duration="0:0:4"/>
        </Storyboard>

        <Storyboard x:Key="FloatingNotificationSlideOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="FloatingNotificationTranslate"
                             Storyboard.TargetProperty="Y"
                             To="18"
                             Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="FloatingNotificationBanner"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            MaxWidth="320"
            BorderThickness="0"
            CornerRadius="0">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background"
                        Value="{DynamicResource Brush.NotificationInfoBackground}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IconType, ElementName=Root}"
                                 Value="{x:Static vm:NotificationIconType.Warning}">
                        <Setter Property="Background"
                                Value="{DynamicResource Brush.NotificationWarningBackground}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IconType, ElementName=Root}"
                                 Value="{x:Static vm:NotificationIconType.Error}">
                        <Setter Property="Background"
                                Value="{DynamicResource Brush.NotificationErrorBackground}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="5"
                              Opacity="0.28"
                              Color="#000000"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="FloatingNotificationTranslate"
                                Y="18"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
            </Grid.RowDefinitions>
            <Grid Margin="14,10,14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Column="0"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Margin="0,0,2,0"
                           VerticalAlignment="Top">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility"
                                    Value="Collapsed"/>
                            <Setter Property="Opacity"
                                    Value="0.96"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IconType, ElementName=Root}"
                                             Value="{x:Static vm:NotificationIconType.Info}">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                    <Setter Property="Text"
                                            Value="&#xE946;"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource Brush.NotificationInfoBorder}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IconType, ElementName=Root}"
                                             Value="{x:Static vm:NotificationIconType.Warning}">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                    <Setter Property="Text"
                                            Value="&#xE7BA;"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource Brush.NotificationWarningBorder}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IconType, ElementName=Root}"
                                             Value="{x:Static vm:NotificationIconType.Error}">
                                    <Setter Property="Visibility"
                                            Value="Visible"/>
                                    <Setter Property="Text"
                                            Value="&#xEA39;"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource Brush.NotificationErrorBorder}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="2"
                           FontSize="12"
                           Foreground="{DynamicResource Brush.TextPrimary}"
                           TextWrapping="Wrap"
                           Text="{Binding Message, ElementName=Root}"/>
                <StackPanel Grid.Row="1"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,6,0,0">
                    <Button Content="{Binding ActionText, ElementName=Root}"
                            Visibility="{Binding ActionVisibility, ElementName=Root}"
                            Click="ActionButton_Click"
                            Cursor="Hand"
                            FontSize="11"
                            Padding="0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"
                                        Value="Transparent"/>
                                <Setter Property="BorderThickness"
                                        Value="0"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource Brush.TextPrimary}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       TextDecorations="Underline"
                                                       Padding="{TemplateBinding Padding}"
                                                       Cursor="Hand"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver"
                                                         Value="True">
                                                    <Setter Property="Foreground"
                                                            Value="{DynamicResource Brush.NotificationInfoBorder}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource Brush.NotificationProgressTrack}"
                    BorderThickness="1"
                    Background="{DynamicResource Brush.NotificationProgressTrack}"
                    CornerRadius="0">
                <Border HorizontalAlignment="Stretch"
                        Background="{DynamicResource Brush.NotificationProgressValue}"
                        CornerRadius="0"
                        RenderTransformOrigin="0,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="FloatingNotificationProgressScale"
                                        ScaleX="1"/>
                    </Border.RenderTransform>
                </Border>
            </Border>
        </Grid>
    </Border>
</UserControl>