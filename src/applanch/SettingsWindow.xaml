<Window x:Class="applanch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:applanch.Properties"
        xmlns:local="clr-namespace:applanch"
        SizeToContent="Manual"
        Width="480"
        Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Title="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Window_Settings]}"
        SourceInitialized="Window_SourceInitialized"
        Background="{DynamicResource Brush.AppBackground}">
    <Window.Resources>
        <Style x:Key="SettingsCheckBoxStyle"
               TargetType="CheckBox">
            <Setter Property="Foreground"
                    Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Track"
                                    Grid.Column="0"
                                    Width="42"
                                    Height="24"
                                    Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.ItemBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Ellipse x:Name="Thumb"
                                         Width="18"
                                         Height="18"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         Fill="{DynamicResource Brush.TextTertiary}"/>
                            </Border>
                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="Track"
                                        Property="Background"
                                        Value="#1A6DB3F8"/>
                                <Setter TargetName="Track"
                                        Property="BorderBrush"
                                        Value="#6DB3F8"/>
                                <Setter TargetName="Thumb"
                                        Property="HorizontalAlignment"
                                        Value="Right"/>
                                <Setter TargetName="Thumb"
                                        Property="Fill"
                                        Value="#6DB3F8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Track"
                                        Property="BorderBrush"
                                        Value="#8DBFFB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBarThumbStyle"
               TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="OverridesDefaultStyle"
                    Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                CornerRadius="3"
                                Background="{DynamicResource Brush.TextTertiary}"
                                Opacity="0.45"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ThumbBorder"
                                        Property="Opacity"
                                        Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsDragging"
                                     Value="True">
                                <Setter TargetName="ThumbBorder"
                                        Property="Opacity"
                                        Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBarPageButtonStyle"
               TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="OverridesDefaultStyle"
                    Value="True"/>
            <Setter Property="Focusable"
                    Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBarTemplate"
                         TargetType="ScrollBar">
            <Grid Width="6"
                  Margin="0,2">
                <Track x:Name="PART_Track"
                       IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ModernScrollBarPageButtonStyle}"
                                      Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ModernScrollBarPageButtonStyle}"
                                      Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ModernScrollBarThumbStyle}"
                               Margin="1,0"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="HorizontalScrollBarTemplate"
                         TargetType="ScrollBar">
            <Grid Height="6"
                  Margin="2,0">
                <Track x:Name="PART_Track">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ModernScrollBarPageButtonStyle}"
                                      Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ModernScrollBarPageButtonStyle}"
                                      Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ModernScrollBarThumbStyle}"
                               Margin="0,1"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels"
                    Value="True"/>
            <Setter Property="OverridesDefaultStyle"
                    Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation"
                         Value="Vertical">
                    <Setter Property="Width"
                            Value="6"/>
                    <Setter Property="MinWidth"
                            Value="6"/>
                    <Setter Property="Template"
                            Value="{StaticResource VerticalScrollBarTemplate}"/>
                </Trigger>
                <Trigger Property="Orientation"
                         Value="Horizontal">
                    <Setter Property="Height"
                            Value="6"/>
                    <Setter Property="MinHeight"
                            Value="6"/>
                    <Setter Property="Template"
                            Value="{StaticResource HorizontalScrollBarTemplate}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource Brush.ItemBorder}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Button HorizontalAlignment="Left"
                    Style="{StaticResource RoundedButtonStyle}"
                    Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Button_ResetToDefaults]}"
                    Click="ResetToDefaults_Click"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Section_Appearance]}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>

            <Border Margin="0,10,0,20"
                    Padding="14,12"
                    Background="{DynamicResource Brush.ItemBackground}"
                    BorderBrush="{DynamicResource Brush.ItemBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_Theme]}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextPrimary}"/>

                    <ComboBox Grid.Row="0"
                              Grid.Column="1"
                              Width="200"
                              Margin="12,0,0,0"
                              Style="{StaticResource RoundedComboBoxStyle}"
                              SelectedIndex="{Binding ThemeIndex}">
                        <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Theme_System]}"/>
                        <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Theme_Light]}"/>
                        <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Theme_Dark]}"/>
                    </ComboBox>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_Language]}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextPrimary}"/>

                    <ComboBox Grid.Row="2"
                              Grid.Column="1"
                              Width="200"
                              Margin="12,0,0,0"
                              Style="{StaticResource RoundedComboBoxStyle}"
                              SelectedIndex="{Binding LanguageIndex}">
                        <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Language_System]}"/>
                        <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Language_English]}"/>
                        <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Language_Japanese]}"/>
                    </ComboBox>
                </Grid>
            </Border>

            <TextBlock Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Section_Behavior]}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>

            <Border Margin="0,10,0,20"
                    Padding="14,12"
                    Background="{DynamicResource Brush.ItemBackground}"
                    BorderBrush="{DynamicResource Brush.ItemBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <CheckBox Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_StartMinimizedOnLaunch]}"
                              IsChecked="{Binding StartMinimizedOnLaunch}"
                              Style="{StaticResource SettingsCheckBoxStyle}"/>
                    <TextBlock Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_StartMinimizedOnLaunchDesc]}"
                               Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource Brush.TextTertiary}"
                               TextWrapping="Wrap"/>

                    <CheckBox Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_LaunchAtWindowsStartup]}"
                              IsChecked="{Binding LaunchAtWindowsStartup}"
                              Margin="0,14,0,0"
                              Style="{StaticResource SettingsCheckBoxStyle}"/>
                    <TextBlock Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_LaunchAtWindowsStartupDesc]}"
                               Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource Brush.TextTertiary}"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_PostLaunchBehavior]}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <ComboBox Grid.Column="1"
                                  Width="200"
                                  Margin="12,0,0,0"
                                  HorizontalAlignment="Left"
                                  Style="{StaticResource RoundedComboBoxStyle}"
                                  SelectedIndex="{Binding PostLaunchBehaviorIndex}">
                            <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[PostLaunchBehavior_Close]}"/>
                            <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[PostLaunchBehavior_Minimize]}"/>
                            <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[PostLaunchBehavior_KeepOpen]}"/>
                        </ComboBox>
                    </Grid>

                    <CheckBox Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_ConfirmBeforeLaunch]}"
                              IsChecked="{Binding ConfirmBeforeLaunch}"
                              Margin="0,14,0,0"
                              Style="{StaticResource SettingsCheckBoxStyle}"/>
                    <CheckBox Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_ConfirmBeforeDelete]}"
                              IsChecked="{Binding ConfirmBeforeDelete}"
                              Margin="0,10,0,0"
                              Style="{StaticResource SettingsCheckBoxStyle}"/>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_CategorySortMode]}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <ComboBox Grid.Column="1"
                                  Width="200"
                                  Margin="12,0,0,0"
                                  HorizontalAlignment="Left"
                                  Style="{StaticResource RoundedComboBoxStyle}"
                                  SelectedIndex="{Binding CategorySortModeIndex}">
                            <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[SortMode_Alphabetical]}"/>
                            <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[SortMode_AsAdded]}"/>
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_AppListSortMode]}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <ComboBox Grid.Column="1"
                                  Width="200"
                                  Margin="12,0,0,0"
                                  HorizontalAlignment="Left"
                                  Style="{StaticResource RoundedComboBoxStyle}"
                                  SelectedIndex="{Binding AppListSortModeIndex}">
                            <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[AppListSort_Manual]}"/>
                            <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[AppListSort_Name]}"/>
                            <ComboBoxItem Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[AppListSort_CategoryThenName]}"/>
                        </ComboBox>
                    </Grid>

                    <CheckBox Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_RunAsAdministrator]}"
                              IsChecked="{Binding RunAsAdministrator}"
                              Margin="0,14,0,0"
                              Style="{StaticResource SettingsCheckBoxStyle}"/>

                    <CheckBox Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_CheckForUpdates]}"
                              IsChecked="{Binding CheckForUpdatesOnStartup}"
                              Margin="0,14,0,0"
                              Style="{StaticResource SettingsCheckBoxStyle}"/>
                    <TextBlock Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_CheckForUpdatesDesc]}"
                               Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource Brush.TextTertiary}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Section_Debug]}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>

            <Border Margin="0,10,0,0"
                    Padding="14,12"
                    Background="{DynamicResource Brush.ItemBackground}"
                    BorderBrush="{DynamicResource Brush.ItemBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <CheckBox Content="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_DebugUpdate]}"
                              IsChecked="{Binding DebugUpdate}"
                              Style="{StaticResource SettingsCheckBoxStyle}"/>
                    <TextBlock Text="{Binding Source={x:Static local:LocalizedStrings.Instance}, Path=[Setting_DebugUpdateDesc]}"
                               Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource Brush.TextTertiary}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
