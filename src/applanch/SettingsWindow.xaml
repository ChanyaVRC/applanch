<Window x:Class="applanch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:applanch.Properties"
        SizeToContent="Height"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Title="{x:Static res:Resources.Window_Settings}"
        SourceInitialized="Window_SourceInitialized"
        Background="{DynamicResource Brush.AppBackground}">
    <Window.Resources>
        <Style x:Key="SettingsCheckBoxStyle"
               TargetType="CheckBox">
            <Setter Property="Foreground"
                    Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Track"
                                    Grid.Column="0"
                                    Width="42"
                                    Height="24"
                                    Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.ItemBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Ellipse x:Name="Thumb"
                                         Width="18"
                                         Height="18"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         Fill="{DynamicResource Brush.TextTertiary}"/>
                            </Border>
                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="Track"
                                        Property="Background"
                                        Value="#1A6DB3F8"/>
                                <Setter TargetName="Track"
                                        Property="BorderBrush"
                                        Value="#6DB3F8"/>
                                <Setter TargetName="Thumb"
                                        Property="HorizontalAlignment"
                                        Value="Right"/>
                                <Setter TargetName="Thumb"
                                        Property="Fill"
                                        Value="#6DB3F8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Track"
                                        Property="BorderBrush"
                                        Value="#8DBFFB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="{x:Static res:Resources.Section_Appearance}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.TextPrimary}"/>

        <Border Margin="0,10,0,20"
                Padding="14,12"
                Background="{DynamicResource Brush.ItemBackground}"
                BorderBrush="{DynamicResource Brush.ItemBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{x:Static res:Resources.Setting_Theme}"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextPrimary}"/>

                <ComboBox Grid.Column="1"
                          Width="170"
                          Margin="12,0,0,0"
                          Style="{StaticResource RoundedComboBoxStyle}"
                          SelectedIndex="{Binding ThemeIndex}">
                    <ComboBoxItem Content="{x:Static res:Resources.Theme_System}"/>
                    <ComboBoxItem Content="{x:Static res:Resources.Theme_Light}"/>
                    <ComboBoxItem Content="{x:Static res:Resources.Theme_Dark}"/>
                </ComboBox>
            </Grid>
        </Border>

        <TextBlock Text="{x:Static res:Resources.Section_Behavior}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.TextPrimary}"/>

        <Border Margin="0,10,0,20"
                Padding="14,12"
                Background="{DynamicResource Brush.ItemBackground}"
                BorderBrush="{DynamicResource Brush.ItemBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <CheckBox Content="{x:Static res:Resources.Setting_CloseOnLaunch}"
                          IsChecked="{Binding CloseOnLaunch}"
                          Style="{StaticResource SettingsCheckBoxStyle}"/>
                <TextBlock Text="{x:Static res:Resources.Setting_CloseOnLaunchDesc}"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.TextTertiary}"
                           TextWrapping="Wrap"/>

                <CheckBox Content="{x:Static res:Resources.Setting_CheckForUpdates}"
                          IsChecked="{Binding CheckForUpdatesOnStartup}"
                          Margin="0,14,0,0"
                          Style="{StaticResource SettingsCheckBoxStyle}"/>
                <TextBlock Text="{x:Static res:Resources.Setting_CheckForUpdatesDesc}"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.TextTertiary}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

            <TextBlock Text="{x:Static res:Resources.Section_Debug}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.TextPrimary}"/>

        <Border Margin="0,10,0,0"
                Padding="14,12"
                Background="{DynamicResource Brush.ItemBackground}"
                BorderBrush="{DynamicResource Brush.ItemBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <CheckBox Content="{x:Static res:Resources.Setting_DebugUpdate}"
                          IsChecked="{Binding DebugUpdate}"
                          Style="{StaticResource SettingsCheckBoxStyle}"/>
                <TextBlock Text="{x:Static res:Resources.Setting_DebugUpdateDesc}"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.TextTertiary}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
