<Window x:Class="applanch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="Height"
        Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Title="設定"
        Background="{DynamicResource Brush.AppBackground}">
    <Window.Resources>
        <Style x:Key="SettingsCheckBoxStyle"
               TargetType="CheckBox">
            <Setter Property="Foreground"
                    Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Track"
                                    Grid.Column="0"
                                    Width="42"
                                    Height="24"
                                    Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.ItemBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Ellipse x:Name="Thumb"
                                         Width="18"
                                         Height="18"
                                         Margin="2"
                                         HorizontalAlignment="Left"
                                         Fill="{DynamicResource Brush.TextTertiary}"/>
                            </Border>
                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="Track"
                                        Property="Background"
                                        Value="#1A6DB3F8"/>
                                <Setter TargetName="Track"
                                        Property="BorderBrush"
                                        Value="#6DB3F8"/>
                                <Setter TargetName="Thumb"
                                        Property="HorizontalAlignment"
                                        Value="Right"/>
                                <Setter TargetName="Thumb"
                                        Property="Fill"
                                        Value="#6DB3F8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Track"
                                        Property="BorderBrush"
                                        Value="#8DBFFB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter Property="Opacity"
                                        Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="外観"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.TextPrimary}"/>

        <Border Margin="0,10,0,20"
                Padding="14,12"
                Background="{DynamicResource Brush.ItemBackground}"
                BorderBrush="{DynamicResource Brush.ItemBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="テーマ"
                           FontSize="13"
                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                <ComboBox x:Name="ThemeComboBox"
                          Margin="0,8,0,0"
                          Style="{StaticResource RoundedComboBoxStyle}"
                          SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="システムに従う"/>
                    <ComboBoxItem Content="ライト"/>
                    <ComboBoxItem Content="ダーク"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <TextBlock Text="動作"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.TextPrimary}"/>

        <Border Margin="0,10,0,20"
                Padding="14,12"
                Background="{DynamicResource Brush.ItemBackground}"
                BorderBrush="{DynamicResource Brush.ItemBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <CheckBox x:Name="CloseOnLaunchCheckBox"
                          Content="起動後にアプリを閉じる"
                          Checked="CloseOnLaunchCheckBox_Changed"
                          Unchecked="CloseOnLaunchCheckBox_Changed"
                          Style="{StaticResource SettingsCheckBoxStyle}"/>
                <TextBlock Text="有効にすると、アイテムを起動した後に Applanch を終了します。"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.TextTertiary}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock Text="デバッグ"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.TextPrimary}"/>

        <Border Margin="0,10,0,0"
                Padding="14,12"
                Background="{DynamicResource Brush.ItemBackground}"
                BorderBrush="{DynamicResource Brush.ItemBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <CheckBox x:Name="DebugUpdateCheckBox"
                          Content="アップデートのデバッグモード"
                                                  Checked="DebugUpdateCheckBox_Changed"
                                                  Unchecked="DebugUpdateCheckBox_Changed"
                          Style="{StaticResource SettingsCheckBoxStyle}"/>
                <TextBlock Text="有効にすると、現在のバージョンに関わらず最新リリースへのアップデートを常に提示します。"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource Brush.TextTertiary}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
