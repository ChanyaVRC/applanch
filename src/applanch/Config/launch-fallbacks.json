{
  "rules": [
    {
      "name": "Riot VALORANT",
      "kind": "command-template",
      "enabled": true,
      "fallbackTrigger": "always",
      "matchFileNames": ["VALORANT.exe", "VALORANT-Win64-Shipping.exe"],
      "fileNameTemplate": "{ancestorPath:Riot Games}\\Riot Client\\RiotClientServices.exe",
      "argumentsTemplate": "--launch-product={product} --launch-patchline={patchline}",
      "product": "valorant",
      "patchline": "live"
    },
    {
      "name": "Riot League of Legends",
      "kind": "command-template",
      "enabled": true,
      "fallbackTrigger": "always",
      "matchFileNames": ["LeagueClient.exe", "LeagueClientUx.exe", "League of Legends.exe"],
      "fileNameTemplate": "{ancestorPath:Riot Games}\\Riot Client\\RiotClientServices.exe",
      "argumentsTemplate": "--launch-product={product} --launch-patchline={patchline}",
      "product": "league_of_legends",
      "patchline": "live"
    },
    {
      "name": "Steam library executable",
      "kind": "uri-template",
      "enabled": true,
      "fallbackTrigger": "always",
      "pathContains": "steamapps/common/",
      "uriTemplate": "steam://rungameid/{appId}",
      "appIdSource": "steam-manifest"
    },
    {
      "name": "Epic Games sample",
      "kind": "uri-template",
      "enabled": false,
      "matchFileNames": ["GameExecutable.exe"],
      "uriTemplate": "com.epicgames.launcher://apps/{appId}?action=launch&silent=true",
      "appId": "REPLACE_WITH_EPIC_APP_ID"
    },
    {
      "name": "Ubisoft Connect sample",
      "kind": "uri-template",
      "enabled": false,
      "matchFileNames": ["GameExecutable.exe"],
      "uriTemplate": "uplay://launch/{appId}/0",
      "appId": "REPLACE_WITH_UPLAY_GAME_ID"
    },
    {
      "name": "EA app sample",
      "kind": "uri-template",
      "enabled": false,
      "matchFileNames": ["GameExecutable.exe"],
      "uriTemplate": "ea://launchgame/{appId}",
      "appId": "REPLACE_WITH_EA_APP_ID"
    },
    {
      "name": "Battle.net sample",
      "kind": "uri-template",
      "enabled": false,
      "matchFileNames": ["GameExecutable.exe"],
      "uriTemplate": "battlenet://{appId}",
      "appId": "REPLACE_WITH_BATTLENET_GAME_ID"
    },
    {
      "name": "Generic launcher executable sample",
      "kind": "command-template",
      "enabled": false,
      "matchFileNames": ["GameExecutable.exe"],
      "fileNameTemplate": "%ProgramFiles(x86)%\\Example Launcher\\launcher.exe",
      "argumentsTemplate": "launch --game {appId} --path {launchPathQuoted}",
      "appId": "REPLACE_WITH_GAME_ID"
    },
    {
      "name": "Custom URI sample",
      "kind": "uri-template",
      "enabled": false,
      "matchFileNames": ["GameExecutable.exe"],
      "uriTemplate": "example-launcher://launch/{appId}?exe={launchFileName}",
      "appId": "REPLACE_WITH_GAME_ID"
    }
  ]
}
